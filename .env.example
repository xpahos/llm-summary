# Copy to .env and fill in. Used by docker-compose `env_file` and the entrypoint.
# Secrets only — never commit the real .env.
# Priority: environment variables > config.toml > built-in defaults.

# --- Secrets (required for a real run) -------------------------------------

# GitHub API token with repo read access.
GITHUB_TOKEN=

# OpenAI (or compatible) API key used by langchain-openai.
# OPENAI_API_KEY is accepted as a fallback.
LLM_API_KEY=

# --- Corporate proxy (optional) --------------------------------------------

# Route all outbound traffic (GitHub + LLM) through a proxy.
# Use socks5h:// so DNS is resolved on the proxy (typical for corp networks).
# LLM_SUMMARY_PROXY wins over config.toml; standard ALL_PROXY/HTTPS_PROXY also work.
# In Docker, a proxy on the host is reached via host.docker.internal, NOT localhost.
# LLM_SUMMARY_PROXY=socks5h://host.docker.internal:1080
# LLM_SUMMARY_PROXY=socks5h://user:pass@proxy.corp:1080

# --- Optional overrides (otherwise taken from config.toml / defaults) -------

# GITHUB_REPO=tianocore/edk2
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# LLM_BASE_URL=
# LLM_TEMPERATURE=0.2
# CRAWLER_TIMEZONE=UTC
# CRAWLER_DEFAULT_BOOTSTRAP_DAYS=1

# Storage paths (already set in docker-compose.yml; override only if needed):
# LLM_SUMMARY_DB=/data/llm-summary.sqlite
# LLM_SUMMARY_SITE=/site
# LLM_SUMMARY_CONFIG=/config/config.toml
